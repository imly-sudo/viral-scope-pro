{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/update_trending.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/analyze",
      "dest": "api/index.py"
    },
    {
      "src": "/api/trending",
      "dest": "api/index.py"
    },
    {
      "src": "/api/health",
      "dest": "api/index.py"
    },
    {
      "src": "/api/cron/trending",
      "dest": "api/update_trending.py"
    },
    {
      "src": "/(.*)",
      "dest": "static/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/trending",
      "schedule": "0 8 * * *"
    }
  ]
}
